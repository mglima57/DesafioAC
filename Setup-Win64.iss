; Script generated by the Inno Setup Script Wizard.
[Setup]
AppName=Gestao Clientes
AppVerName=Gestao Clientes para Windows 64
OutputBaseFilename=Setup-Win64
AppPublisher=Grupo DESAFIOAC
AppPublisherURL=http://www.DESAFIOAC.com.br/
AppSupportURL=http://www.DESAFIOAC.com.br/
AppUpdatesURL=http://www.DESAFIOAC.com.br/
UsePreviousAppDir=no
DefaultDirName=C:\DESAFIOAC
DisableDirPage=false
DefaultGroupName=Grupo DESAFIOAC
DisableProgramGroupPage=true
OutputDir=E:\Instalacao
SetupIconFile=E:\Imagens\NOTE05.ICO
Compression=lzma
SolidCompression=true
UserInfoPage=false
UninstallDisplayIcon={app}\DESAFIOAC.exe
UninstallDisplayName=Grupo DESAFIOAC
UsePreviousGroup=false
PrivilegesRequired=admin
InternalCompressLevel=normal
;MinVersion=0,6.0.6000
EnableDirDoesntExistWarning=true

[Languages]
Name: brazilianportuguese; MessagesFile: compiler:Languages\BrazilianPortuguese.isl

[Run]
;Filename: {app}\DESAFIOACUpdateOffLine.exe; Flags: shellexec postinstall runascurrentuser runminimized hidewizard; StatusMsg: Atualizando Banco de Dados com o PostScrip.SQL; Description: Atualizar Objetos do Banco de Dados; WorkingDir: {app}; Components: Atualizacao

[Tasks]
Name: desktopicon; Description: {cm:CreateDesktopIcon}; GroupDescription: {cm:AdditionalIcons}

