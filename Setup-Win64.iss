[Components]
Name: Atualizacao; Description: Atualizaçăo dos Componentes Já Instalados; Flags: exclusive disablenouninstallwarning; Types: full; Languages: 
Name: Instalacao; Description: Instalaçăo Completa dos Componentes; Flags: exclusive disablenouninstallwarning; Types: full; Languages: 

[Code]
// X64
function IsX64: Boolean;
begin
  //Result := Is64BitInstallMode and (ProcessorArchitecture = paX64);
  Result := ProcessorArchitecture = paX64;
end;

// IA64
function IsIA64: Boolean;
begin
  //Result := Is64BitInstallMode and (ProcessorArchitecture = paIA64);
  Result := ProcessorArchitecture = paIA64;
end;

function IsOtherArch: Boolean;
begin
  Result := not IsX64 and not IsIA64;
end;

function IsWindowsXP: Boolean;
var
  Version: TWindowsVersion;
  S: String;
begin
  GetWindowsVersionEx(Version);
  Result := Version.NTPlatform and (Version.Major = 5) and (Version.Minor = 1);
end;

function InitializeSetup(): Boolean;
begin
    if not IsX64 and not IsIA64 then begin
        MsgBox('Este Programa requer Sistema Operacional de 64 bits, processador com base em x64.'#13#13
            'Por favor utilizar SETUP correspondente ao seu Sistema Operacional para Instalar esta versăo.'#13
            'e rode novamente este Setup.', mbInformation, MB_OK);
        result := false;

    end else
	begin

        result := true;
    end ;
end;
